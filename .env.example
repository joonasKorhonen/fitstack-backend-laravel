APP_NAME=FitStack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fitstack
DB_USERNAME=fitstack
DB_PASSWORD=fitstack_dev_password

SESSION_DRIVER=cookie
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# JWT — must match the value used by fitstack-backend (NestJS) so both backends
# can share the same database without re-issuing tokens when switching.
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080

# AWS (S3 for avatars, SES for password-reset emails)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=

MAIL_MAILER=ses
MAIL_FROM_ADDRESS=noreply@fitstack.app
MAIL_FROM_NAME=FitStack

# URL of the running frontend — used for CORS and password-reset email links
FRONTEND_URL=http://localhost:3000
